# .env.example
# Copy to .env.local for local dev. Set these in the Vercel dashboard for prod.
# Do NOT commit your real .env file.

# Anthropic API key. Same one already in your Vercel project.
ANTHROPIC_API_KEY=sk-ant-...

# Postgres connection string. Vercel Postgres auto-injects POSTGRES_URL
# when you connect the integration; that's what @vercel/postgres reads.
# Only set this manually for local development.
POSTGRES_URL=postgresql://user:pass@host:5432/db

# Comma-separated list of origins allowed to call /api/* endpoints.
# Add the exact origin Kajabi serves your page from. You can find this by
# opening your Kajabi page in a browser, opening devtools, and reading
# window.location.origin.
# Example: https://shimritnativ.kajabi.com,https://yourdomain.com
ALLOWED_ORIGINS=https://shimritnativ.kajabi.com

# Secret used to sign session tokens. Any long random string. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
SESSION_SECRET=replace_with_a_random_48_byte_string

# NODE_ENV=production is auto-set by Vercel in prod. Setting it locally
# disables the dev-only CORS fallback (which allows requests with no Origin).
NODE_ENV=development
